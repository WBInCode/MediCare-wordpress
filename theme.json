{
  "version": 3,
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        { "slug": "primary", "color": "#c9a0a0", "name": "Primary Rose" },
        { "slug": "secondary", "color": "#f5e6e0", "name": "Soft Blush" },
        { "slug": "accent", "color": "#b08968", "name": "Warm Gold" },
        { "slug": "dark", "color": "#2d2d2d", "name": "Charcoal" },
        { "slug": "background", "color": "#faf8f7", "name": "Warm White" },
        { "slug": "foreground", "color": "#3a3a3a", "name": "Text Dark" },
        { "slug": "muted", "color": "#8a8a8a", "name": "Muted" },
        { "slug": "light-pink", "color": "#fdf2f0", "name": "Light Pink" },
        { "slug": "white", "color": "#ffffff", "name": "White" }
      ],
      "defaultPalette": false,
      "defaultGradients": false,
      "gradients": [
        {
          "slug": "rose-to-blush",
          "name": "Rose to Blush",
          "gradient": "linear-gradient(135deg, #c9a0a0 0%, #f5e6e0 100%)"
        },
        {
          "slug": "blush-to-white",
          "name": "Blush to White",
          "gradient": "linear-gradient(180deg, #fdf2f0 0%, #ffffff 100%)"
        }
      ]
    },
    "typography": {
      "fluid": true,
      "fontFamilies": [
        {
          "slug": "heading",
          "name": "Heading",
          "fontFamily": "'Playfair Display', Georgia, serif"
        },
        {
          "slug": "body",
          "name": "Body",
          "fontFamily": "'Inter', system-ui, -apple-system, 'Segoe UI', sans-serif"
        },
        {
          "slug": "accent",
          "name": "Accent",
          "fontFamily": "'Cormorant Garamond', Georgia, serif"
        }
      ],
      "fontSizes": [
        { "slug": "small", "size": "0.875rem", "fluid": { "min": "0.813rem", "max": "0.875rem" } },
        { "slug": "medium", "size": "1rem", "fluid": { "min": "0.938rem", "max": "1rem" } },
        { "slug": "large", "size": "1.25rem", "fluid": { "min": "1.125rem", "max": "1.25rem" } },
        { "slug": "x-large", "size": "2rem", "fluid": { "min": "1.5rem", "max": "2rem" } },
        { "slug": "xx-large", "size": "3.5rem", "fluid": { "min": "2rem", "max": "3.5rem" } },
        { "slug": "hero", "size": "5rem", "fluid": { "min": "2.5rem", "max": "5rem" } }
      ]
    },
    "spacing": {
      "units": ["px", "rem", "%", "vw"],
      "spacingSizes": [
        { "slug": "10", "size": "0.25rem", "name": "4px" },
        { "slug": "20", "size": "0.5rem", "name": "8px" },
        { "slug": "30", "size": "1rem", "name": "16px" },
        { "slug": "40", "size": "1.5rem", "name": "24px" },
        { "slug": "50", "size": "2.5rem", "name": "40px" },
        { "slug": "60", "size": "4rem", "name": "64px" },
        { "slug": "70", "size": "6rem", "name": "96px" },
        { "slug": "80", "size": "8rem", "name": "128px" }
      ]
    },
    "layout": {
      "contentSize": "780px",
      "wideSize": "1280px"
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--background)",
      "text": "var(--wp--preset--color--foreground)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body)",
      "fontSize": "var(--wp--preset--font-size--medium)",
      "lineHeight": "1.7"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontWeight": "600",
          "lineHeight": "1.2"
        },
        "color": {
          "text": "var(--wp--preset--color--dark)"
        }
      },
      "link": {
        "color": { "text": "var(--wp--preset--color--primary)" },
        ":hover": { "color": { "text": "var(--wp--preset--color--accent)" } }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--white)"
        },
        "border": { "radius": "50px" },
        ":hover": {
          "color": { "background": "var(--wp--preset--color--accent)" }
        }
      }
    }
  }
}
